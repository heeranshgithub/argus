# Argus — shared environment reference
# Each app reads its own env file; this documents every variable both need.
#
#   backend  -> backend/.env        (copy from backend/.env.example)
#   frontend -> frontend/.env.local (copy from frontend/.env.local.example)

# ──────────────────────────── Backend (backend/.env) ────────────────────────────

# Runtime environment: dev | prod | test
ENV=dev

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=argus

# Comma-separated list of allowed CORS origins (the frontend's URL)
CORS_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API route prefix
API_PREFIX=/api

# ──────────────────────── Frontend (frontend/.env.local) ────────────────────────

# Base URL of the backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Argus backend environment
# Copy to .env and adjust for your machine.

# Runtime environment: dev | prod | test
ENV=dev

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=argus

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# API route prefix
API_PREFIX=/api

# --- LLM gateway: OpenRouter (Part 3) ----------------------------------------
# Single OpenAI-compatible endpoint proxying hundreds of models. Required to run
# the workflow against real providers; tests use a fake client and need no key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=Argus Research Copilot
# Optional; sent as HTTP-Referer so Argus is identifiable in the OpenRouter dashboard.
OPENROUTER_APP_URL=

# Per-node model slugs (any OpenRouter model). Unset per-node values fall back to
# LLM_MODEL_DEFAULT. Cheap/fast for planner & quality_check; stronger for the rest.
LLM_MODEL_DEFAULT=openai/gpt-4o-mini
LLM_MODEL_ANALYST=anthropic/claude-sonnet-4.6
LLM_MODEL_REPORTER=anthropic/claude-sonnet-4.6
# Comma-separated OpenRouter fallback models (routed around on provider outages).
LLM_FALLBACK_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash

# --- Web search (Part 3) -----------------------------------------------------
# Tavily is primary; without a key the workflow falls back to DuckDuckGo.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# --- Workflow tuning (Part 3) ------------------------------------------------
WORKFLOW_MAX_RESEARCH_ITERATIONS=2
WORKFLOW_NODE_RETRY_LIMIT=2
WORKFLOW_RECURSION_LIMIT=30
FETCH_TIMEOUT_SECONDS=8.0
FETCH_MAX_BYTES=1000000
FETCH_CONCURRENCY=4
SEARCH_RESULTS_PER_QUERY=5

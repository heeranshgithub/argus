# Argus backend environment
# Copy to .env and adjust for your machine.

# Runtime environment: dev | prod | test
ENV=dev

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=argus

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# API route prefix
API_PREFIX=/api
